<div class="social-share d-flex gap-2 mt-3 mb-4">

    <a href="https://www.facebook.com/sharer/sharer.php?u={$link}"
       target="_blank"
       class="share-btn facebook">
        <img src="{$facebook}" alt="Facebook" />
    </a>

    <a href="https://x.com/intent/tweet?url={$link}"
       target="_blank"
       class="share-btn twitter">
        <img src="{$x}" alt="X" />
    </a>

    <a href="https://wa.me/?text={$link}"
       target="_blank"
       class="share-btn whatsapp">
        <img src="{$whatsapp}" alt="Whatsapp" />
    </a>

    <a href="https://pinterest.com/pin/create/button/?url={$link}"
       target="_blank"
       class="share-btn pinterest">
        <img src="{$pin}" alt="Pinterest" />
    </a>

</div>